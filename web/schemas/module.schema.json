{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://personal-os.local/module.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "name", "version", "description", "actions"],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 2,
      "pattern": "^[a-z][a-z0-9_\\-]*$"
    },
    "name": {
      "type": "string",
      "minLength": 2
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 8
    },
    "actions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "name", "description"],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 2,
            "pattern": "^[a-z][a-z0-9_\\-]*$"
          },
          "name": {
            "type": "string",
            "minLength": 2
          },
          "description": {
            "type": "string",
            "minLength": 8
          },
          "toolName": {
            "type": "string",
            "minLength": 2
          },
          "params": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["name", "type", "description"],
              "properties": {
                "name": {
                  "type": "string",
                  "minLength": 1,
                  "pattern": "^[a-zA-Z_][a-zA-Z0-9_]*$"
                },
                "type": {
                  "type": "string",
                  "enum": ["string", "number", "boolean", "array"]
                },
                "required": {
                  "type": "boolean"
                },
                "description": {
                  "type": "string",
                  "minLength": 4
                },
                "enum": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "default": {
                  "oneOf": [
                    { "type": "string" },
                    { "type": "number" },
                    { "type": "boolean" },
                    {
                      "type": "array",
                      "items": { "type": "string" }
                    }
                  ]
                }
              }
            }
          }
        }
      }
    }
  }
}
