# Personal OS Root Directory
PERSONAL_OS_ROOT=/Users/joy/Projects/joy-portfolio/Personal OS/personal-os

# Optional HTTP bridge for MCP-compatible tool invocation
# MCP_BRIDGE_URL=http://127.0.0.1:8787/invoke

# Jira Integration Configuration
# JIRA_BASE_URL=https://your-company.atlassian.net
# JIRA_EMAIL=your-email@company.com
# JIRA_API_TOKEN=your-api-token

# Jira Project Keys and Board IDs (M2P Dual Board Support)
# Mix of project keys and board IDs for CSo/LEN workflow
# JIRA_PROJECT_KEYS=CSO,LEN,PROD
# JIRA_BOARD_IDS=123,456,789

# Charter Mapping Configuration Path
# CHARTER_CONFIG_PATH=.config/charter-mapping.json

# Confluence Integration Configuration
# CONFLUENCE_BASE_URL=https://your-company.atlassian.net/wiki
# CONFLUENCE_EMAIL=your-email@company.com
# CONFLUENCE_API_TOKEN=your-api-token
# CONFLUENCE_SPACE_KEYS=PRODUCT,TECH

# Optional Custom Jira Filters
# JIRA_CUSTOM_FILTERS=assignee=currentUser(),labels=urgent
